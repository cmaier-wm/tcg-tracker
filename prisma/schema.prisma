generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CardCategory {
  id               String    @id @default(cuid())
  sourceCategoryId String    @unique
  name             String
  slug             String    @unique
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sets             CardSet[]
}

model CardSet {
  id            String   @id @default(cuid())
  categoryId    String
  sourceSetId   String   @unique
  name          String
  abbreviation  String?
  releasedOn    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  category      CardCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  cards         Card[]
}

model Card {
  id                 String          @id @default(cuid())
  setId              String
  sourceProductId    String          @unique
  name               String
  cleanName          String
  collectorNumber    String?
  rarity             String?
  imageUrl           String?
  externalProductUrl String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  set                CardSet         @relation(fields: [setId], references: [id], onDelete: Cascade)
  variations         CardVariation[]
}

model CardVariation {
  id             String            @id @default(cuid())
  cardId         String
  sourceSkuId    String?           @unique
  languageCode   String?
  finish         String?
  conditionCode  String?
  variantLabel   String
  isDefault      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  card           Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  priceSnapshots PriceSnapshot[]
  holdings       PortfolioHolding[]

  @@unique([cardId, languageCode, finish, conditionCode, variantLabel])
}

model PriceSnapshot {
  id              String        @id @default(cuid())
  cardVariationId String
  capturedAt      DateTime
  marketPrice     Float?
  lowPrice        Float?
  highPrice       Float?
  listingCount    Int?
  sourceName      String
  createdAt       DateTime      @default(now())
  variation       CardVariation @relation(fields: [cardVariationId], references: [id], onDelete: Cascade)

  @@unique([cardVariationId, sourceName, capturedAt])
}

model UserAccount {
  id                   String                     @id @default(cuid())
  email                String                     @unique
  displayName          String
  isLegacyDefault      Boolean                    @default(false)
  legacyClaimedAt      DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  credential           UserCredential?
  authSessions         AuthSession[]
  authAuditEvents      AuthAuditEvent[]
  passwordResetTokens  PasswordResetToken[]
  holdings             PortfolioHolding[]
  valuationSnapshots PortfolioValuationSnapshot[]
  teamsAlertPreference TeamsAlertPreference?
  teamsAlertDeliveries TeamsAlertDelivery[]
}

model UserCredential {
  userId           String      @id
  normalizedEmail  String      @unique
  passwordHash     String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id           String      @id @default(cuid())
  userId       String
  sessionToken String      @unique
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model AuthAuditEvent {
  id         String      @id @default(cuid())
  userId     String?
  eventType  String
  outcome    String
  detail     String?
  createdAt  DateTime    @default(now())
  user       UserAccount? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model PasswordResetToken {
  id         String      @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())
  user       UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model PortfolioHolding {
  id              String        @id @default(cuid())
  userId          String
  cardVariationId String
  quantity        Int
  notes           String?
  acquiredAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            UserAccount   @relation(fields: [userId], references: [id], onDelete: Cascade)
  variation       CardVariation @relation(fields: [cardVariationId], references: [id], onDelete: Cascade)

  @@unique([userId, cardVariationId])
}

model PortfolioValuationSnapshot {
  id                 String      @id @default(cuid())
  userId             String
  capturedAt         DateTime
  totalValue         Float
  holdingCount       Int
  pricedHoldingCount Int
  createdAt          DateTime    @default(now())
  user               UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, capturedAt])
}

model TeamsAlertPreference {
  id                  String               @id @default(cuid())
  userId              String               @unique
  enabled             Boolean              @default(false)
  destinationLabel    String?
  triggerAmountUsd    Int                  @default(1000)
  encryptedWebhookUrl String?
  webhookUrlIv        String?
  baselineValue       Float?
  lastEvaluatedAt     DateTime?
  lastDeliveredAt     DateTime?
  lastFailureAt       DateTime?
  lastFailureMessage  String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                UserAccount          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries          TeamsAlertDelivery[]
}

model TeamsAlertDelivery {
  id             String               @id @default(cuid())
  userId         String
  preferenceId   String
  capturedAt     DateTime
  portfolioValue Float
  baselineValue  Float
  gainAmount     Float
  status         String
  failureMessage String?
  responseCode   Int?
  createdAt      DateTime             @default(now())
  user           UserAccount          @relation(fields: [userId], references: [id], onDelete: Cascade)
  preference     TeamsAlertPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([preferenceId, createdAt])
}
