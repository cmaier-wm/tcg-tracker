{
  "name": "tcg-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:up": "node scripts/db-up.mjs up",
    "db:down": "node scripts/db-up.mjs down",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "node scripts/seed-demo-data.mjs",
    "catalog:sync": "node scripts/sync-catalog.mjs",
    "azure:prepare": "node scripts/azure-prepare-env.mjs",
    "azure:package": "node scripts/prepare-azure-package.mjs",
    "azure:verify": "node scripts/azure-verify-deployment.mjs",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration tests/contract",
    "test:e2e": "playwright test",
    "snapshots:run": "node scripts/run-snapshots.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.64.2",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "sonner": "^2.0.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
